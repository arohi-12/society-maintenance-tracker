# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
MONGO_URI=mongodb://127.0.0.1:27017/society_maintenance

# Authentication Secret
JWT_SECRET=replace_this_with_a_secure_random_key_123456

# Seeding Initial Admin User
ADMIN_NAME=Society Admin
ADMIN_EMAIL=admin@society.com
ADMIN_PASSWORD=admin123

# Overdue Complaints Calculation
OVERDUE_THRESHOLD_DAYS=3

# Email Service Configuration (SMTP / Mailtrap)
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_mailtrap_smtp_user
SMTP_PASS=your_mailtrap_smtp_password
FROM_EMAIL="Society Maintenance Board" <noreply@societytracker.com>
